# Application
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info

# Auth (NextAuth + OIDC)
AUTH_SECRET=replace-with-a-random-string-at-least-32-characters-long
AUTH_OIDC_CLIENT_ID=7ice-platform
AUTH_OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
AUTH_OIDC_ISSUER=http://localhost:8180/realms/7ice

# Database (local Docker)
DATABASE_URL=postgresql://7ice:7ice_local_password@localhost:5432/7ice_platform?schema=public
POSTGRES_DB=7ice_platform
POSTGRES_USER=7ice
POSTGRES_PASSWORD=7ice_local_password

# Keycloak (local Docker)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Bootstrap admin (first OIDC login with this email receives administrator role)
BOOTSTRAP_ADMIN_EMAIL=admin@7ice.local

# Nginx (production)
NGINX_PORT=80
