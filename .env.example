# Application
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info

# Auth (NextAuth + OIDC)
AUTH_SECRET=replace-with-a-random-string-at-least-32-characters-long
AUTH_OIDC_CLIENT_ID=your-oidc-client-id
AUTH_OIDC_CLIENT_SECRET=your-oidc-client-secret
AUTH_OIDC_ISSUER=https://your-identity-provider.example.com

# Database
DATABASE_URL=postgresql://7ice:7ice@localhost:5432/7ice

# Docker Compose (PostgreSQL service)
POSTGRES_DB=7ice
POSTGRES_USER=7ice
POSTGRES_PASSWORD=7ice

# Optional: first OIDC login with this email receives the administrator role
# BOOTSTRAP_ADMIN_EMAIL=admin@7ice.local
